# -----------------------------------------------------------------------------
# PAGAMENTOS — Mercado Pago (substituindo Stripe)
# -----------------------------------------------------------------------------
# 📍 Onde encontrar:
#    1. Acesse https://www.mercadopago.com.br/developers
#    2. Vá em Suas integrações → Credenciais
#    3. Em PRODUÇÃO copie o "Public Key" (começa com APP_USR-)
#    4. O "Access Token" (começando com APP_USR-) vai APENAS nas Edge Functions do Supabase
#
# ⚠️  NUNCA exponha o Access Token no frontend!
# -----------------------------------------------------------------------------
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-COLE_SEU_PUBLIC_KEY_AQUI

# -----------------------------------------------------------------------------
# WEB PUSH / PWA — Notificações push (gerado automaticamente)
# -----------------------------------------------------------------------------
# 📍 Como gerar: npx web-push generate-vapid-keys
# A Private Key vai nas Edge Functions do Supabase (não aqui)
# -----------------------------------------------------------------------------
VITE_VAPID_PUBLIC_KEY=BColoqueAquiASuaVapidPublicKeyGerada

# -----------------------------------------------------------------------------
# SENTRY — Monitoramento de erros (opcional)
# -----------------------------------------------------------------------------
# 📍 https://sentry.io → Settings → Projects → Client Keys (DSN)
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Configurações da aplicação
# -----------------------------------------------------------------------------
ENVIRONMENT=production
VITE_APP_URL=https://crm.uautos.com.br
VITE_APP_VERSION=1.0.0

# =============================================================================
# CHECKLIST ANTES DO DEPLOY
# =============================================================================
# [x] VITE_SUPABASE_URL e ANON_KEY — mesmo projeto Supabase do uautos ✅
# [ ] VITE_MERCADOPAGO_PUBLIC_KEY — pegar em mercadopago.com.br/developers
# [ ] Nas Edge Functions do Supabase configurar:
#       - MERCADOPAGO_ACCESS_TOKEN (Access Token de produção)
#       - VAPID_PRIVATE_KEY (gerar com npx web-push generate-vapid-keys)
# [ ] Domínio crm.uautos.com.br configurado no DNS
# [ ] CORS do Supabase: adicionar crm.uautos.com.br na lista de origens permitidas
# =============================================================================